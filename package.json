{
  "name": "truesignal-cli",
  "version": "0.1.1",
  "description": "A provenance-first OSINT/security intelligence feed CLI. Every item ships a real source URL, a real timestamp, and an explicit live/fallback flag -- never a fabricated or silently-replayed data point.",
  "keywords": [
    "osint",
    "security",
    "threat-intelligence",
    "cisa-kev",
    "cve",
    "cli",
    "provenance",
    "cloudflare-radar",
    "gdelt"
  ],
  "homepage": "https://github.com/RudrenduPaul/truesignal#readme",
  "bugs": {
    "url": "https://github.com/RudrenduPaul/truesignal/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrenduPaul/truesignal.git"
  },
  "license": "MIT",
  "author": "Rudrendu Paul",
  "contributors": [
    "Sourav Nandy"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "truesignal": "./dist/cli.js",
    "truesignal-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/truesignal/cli.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit --strict",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
